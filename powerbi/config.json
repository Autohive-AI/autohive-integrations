{
    "name": "Power BI",
    "version": "2.2.0",
    "description": "Power BI integration for managing workspaces, datasets, reports, and dashboards, including report creation via the Microsoft Fabric REST API",
    "entry_point": "powerbi.py",
    "auth": {
        "type": "platform",
        "provider": "Power BI",
        "scopes": [
            "offline_access",
            "Dataset.ReadWrite.All",
            "Report.ReadWrite.All",
            "Dashboard.Read.All",
            "Workspace.ReadWrite.All",
            "Content.Create",
            "Tenant.ReadWrite.All",
            "Item.ReadWrite.All"
        ]
    },
    "actions": {
        "list_workspaces": {
            "display_name": "List Workspaces",
            "description": "Get a list of all Power BI workspaces",
            "input_schema": {
                "type": "object",
                "properties": {
                    "filter": {
                        "type": "string",
                        "description": "Optional OData filter expression"
                    },
                    "top": {
                        "type": "integer",
                        "description": "Maximum number of workspaces to return",
                        "default": 100
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "workspaces": {
                        "type": "array",
                        "description": "List of workspaces",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "isReadOnly": {
                                    "type": "boolean"
                                },
                                "isOnDedicatedCapacity": {
                                    "type": "boolean"
                                },
                                "type": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "workspaces"
                ]
            }
        },
        "get_workspace": {
            "display_name": "Get Workspace",
            "description": "Get details of a specific Power BI workspace",
            "input_schema": {
                "type": "object",
                "properties": {
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID"
                    }
                },
                "required": [
                    "workspace_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "workspace": {
                        "type": "object",
                        "description": "Workspace details"
                    }
                },
                "required": [
                    "workspace"
                ]
            }
        },
        "list_datasets": {
            "display_name": "List Datasets",
            "description": "Get a list of datasets in a workspace",
            "input_schema": {
                "type": "object",
                "properties": {
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "datasets": {
                        "type": "array",
                        "description": "List of datasets",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "configuredBy": {
                                    "type": ["string", "null"]
                                },
                                "isRefreshable": {
                                    "type": "boolean"
                                },
                                "isEffectiveIdentityRequired": {
                                    "type": "boolean"
                                },
                                "isEffectiveIdentityRolesRequired": {
                                    "type": "boolean"
                                },
                                "isOnPremGatewayRequired": {
                                    "type": "boolean"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "datasets"
                ]
            }
        },
        "get_dataset": {
            "display_name": "Get Dataset",
            "description": "Get details of a specific dataset",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "dataset_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "dataset": {
                        "type": "object",
                        "description": "Dataset details"
                    }
                },
                "required": [
                    "dataset"
                ]
            }
        },
        "refresh_dataset": {
            "display_name": "Refresh Dataset",
            "description": "Trigger a refresh for a Power BI dataset with support for enhanced refresh options. Asynchronous - this only starts the refresh and returns immediately; poll get_refresh_history to see when it completes.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset ID to refresh"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    },
                    "notify_option": {
                        "type": "string",
                        "description": "Mail notification options (NoNotification, MailOnFailure, or MailOnCompletion). Not applicable for enhanced refresh or service principal operations.",
                        "enum": [
                            "NoNotification",
                            "MailOnFailure",
                            "MailOnCompletion"
                        ]
                    },
                    "type": {
                        "type": "string",
                        "description": "The type of processing to perform (Full, ClearValues, Calculate, DataOnly, Automatic, or Defragment)",
                        "enum": [
                            "Full",
                            "ClearValues",
                            "Calculate",
                            "DataOnly",
                            "Automatic",
                            "Defragment"
                        ]
                    },
                    "commit_mode": {
                        "type": "string",
                        "description": "Determines if objects will be committed in batches (PartialBatch) or only when complete (Transactional)",
                        "enum": [
                            "Transactional",
                            "PartialBatch"
                        ]
                    },
                    "max_parallelism": {
                        "type": "integer",
                        "description": "The maximum number of threads on which to run parallel processing commands"
                    },
                    "retry_count": {
                        "type": "integer",
                        "description": "Number of times the operation will retry before failing"
                    },
                    "objects": {
                        "type": "array",
                        "description": "An array of objects (tables/partitions) to be processed for selective refresh",
                        "items": {
                            "type": "object",
                            "properties": {
                                "table": {
                                    "type": "string",
                                    "description": "Table name to refresh"
                                },
                                "partition": {
                                    "type": "string",
                                    "description": "Partition name to refresh (optional)"
                                }
                            },
                            "required": [
                                "table"
                            ]
                        }
                    },
                    "apply_refresh_policy": {
                        "type": "boolean",
                        "description": "Determine if the incremental refresh policy is applied or not"
                    },
                    "effective_date": {
                        "type": "string",
                        "description": "If an incremental refresh policy is applied, this parameter overrides the current date (ISO 8601 format)"
                    },
                    "timeout": {
                        "type": "string",
                        "description": "Timeout duration in HH:MM:SS format (e.g., '05:00:00' for 5 hours). Maximum total duration including retries cannot exceed 24 hours.",
                        "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"
                    }
                },
                "required": [
                    "dataset_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "request_id": {
                        "type": ["string", "null"]
                    }
                },
                "required": [
                    "message"
                ]
            }
        },
        "get_refresh_history": {
            "display_name": "Get Dataset Refresh History",
            "description": "Get the refresh history for a dataset, including status (Completed/Failed/Unknown) and start/end times for past refreshes. Works regardless of dataset format, unlike get_dataset_schema.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    },
                    "top": {
                        "type": "integer",
                        "description": "Maximum number of refresh records to return",
                        "default": 10
                    }
                },
                "required": [
                    "dataset_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "refreshes": {
                        "type": "array",
                        "description": "List of refresh records",
                        "items": {
                            "type": "object",
                            "properties": {
                                "refreshType": {
                                    "type": ["string", "null"]
                                },
                                "startTime": {
                                    "type": ["string", "null"]
                                },
                                "endTime": {
                                    "type": ["string", "null"]
                                },
                                "status": {
                                    "type": ["string", "null"]
                                },
                                "requestId": {
                                    "type": ["string", "null"]
                                }
                            }
                        }
                    }
                },
                "required": [
                    "refreshes"
                ]
            }
        },
        "list_reports": {
            "display_name": "List Reports",
            "description": "Get a list of reports in a workspace",
            "input_schema": {
                "type": "object",
                "properties": {
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "reports": {
                        "type": "array",
                        "description": "List of reports",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "webUrl": {
                                    "type": ["string", "null"]
                                },
                                "embedUrl": {
                                    "type": ["string", "null"]
                                },
                                "datasetId": {
                                    "type": ["string", "null"]
                                }
                            }
                        }
                    }
                },
                "required": [
                    "reports"
                ]
            }
        },
        "get_report": {
            "display_name": "Get Report",
            "description": "Get details of a specific report",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "report_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "report": {
                        "type": "object",
                        "description": "Report details"
                    }
                },
                "required": [
                    "report"
                ]
            }
        },
        "get_report_datasources": {
            "display_name": "Get Report Datasources",
            "description": "Get a list of data sources for the specified paginated report (RDL). Only works for RDL/paginated reports - confirmed live that calling this on a standard Power BI report returns a 400 InvalidRequest error rather than data, by API design.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "report_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "datasources": {
                        "type": "array",
                        "description": "List of data sources",
                        "items": {
                            "type": "object",
                            "properties": {
                                "datasourceType": {
                                    "type": ["string", "null"]
                                },
                                "datasourceId": {
                                    "type": ["string", "null"]
                                },
                                "gatewayId": {
                                    "type": ["string", "null"]
                                },
                                "name": {
                                    "type": ["string", "null"]
                                },
                                "connectionString": {
                                    "type": ["string", "null"]
                                },
                                "connectionDetails": {
                                    "type": "object",
                                    "description": "Data source connection details"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "datasources"
                ]
            }
        },
        "clone_report": {
            "display_name": "Clone Report",
            "description": "Clone a Power BI report",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID to clone"
                    },
                    "name": {
                        "type": "string",
                        "description": "Name for the cloned report"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "Source workspace ID (optional, defaults to My workspace)"
                    },
                    "target_workspace_id": {
                        "type": "string",
                        "description": "Target workspace ID (optional, defaults to source workspace)"
                    },
                    "target_dataset_id": {
                        "type": "string",
                        "description": "Target dataset ID for the cloned report (optional)"
                    }
                },
                "required": [
                    "report_id",
                    "name"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "webUrl": {
                        "type": "string"
                    },
                    "embedUrl": {
                        "type": "string"
                    }
                }
            }
        },
        "refresh_report": {
            "display_name": "Refresh Report",
            "description": "Refresh the dataset associated with a Power BI report",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID whose dataset should be refreshed"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    },
                    "notify_option": {
                        "type": "string",
                        "description": "Notification option (NoNotification or MailOnFailure)",
                        "enum": [
                            "NoNotification",
                            "MailOnFailure"
                        ],
                        "default": "NoNotification"
                    }
                },
                "required": [
                    "report_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "dataset_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "message"
                ]
            }
        },
        "export_report": {
            "display_name": "Export Report to File",
            "description": "Export a Power BI report to PDF, PPTX, or PNG. Requires the workspace to be on Power BI Premium or Fabric dedicated capacity - on shared capacity this fails with a 403 InvalidRequest error.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID to export"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    },
                    "format": {
                        "type": "string",
                        "description": "Export format",
                        "enum": [
                            "PDF",
                            "PPTX",
                            "PNG"
                        ],
                        "default": "PDF"
                    }
                },
                "required": [
                    "report_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "export_id": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                },
                "required": [
                    "message"
                ]
            }
        },
        "get_export_status": {
            "display_name": "Get Export Status",
            "description": "Get the status of a report export operation started by export_report. An unknown/invalid export_id returns an error rather than a status - always use the export_id returned by export_report.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID"
                    },
                    "export_id": {
                        "type": "string",
                        "description": "The export ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "report_id",
                    "export_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string"
                    },
                    "percentComplete": {
                        "type": "integer"
                    }
                },
                "required": [
                    "status"
                ]
            }
        },
        "list_dashboards": {
            "display_name": "List Dashboards",
            "description": "Get a list of dashboards in a workspace",
            "input_schema": {
                "type": "object",
                "properties": {
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "dashboards": {
                        "type": "array",
                        "description": "List of dashboards",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "displayName": {
                                    "type": ["string", "null"]
                                },
                                "isReadOnly": {
                                    "type": "boolean"
                                },
                                "embedUrl": {
                                    "type": ["string", "null"]
                                }
                            }
                        }
                    }
                },
                "required": [
                    "dashboards"
                ]
            }
        },
        "get_dashboard": {
            "display_name": "Get Dashboard",
            "description": "Get details of a specific dashboard",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dashboard_id": {
                        "type": "string",
                        "description": "The dashboard ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "dashboard_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "dashboard": {
                        "type": "object",
                        "description": "Dashboard details"
                    }
                },
                "required": [
                    "dashboard"
                ]
            }
        },
        "get_dashboard_tiles": {
            "display_name": "Get Dashboard Tiles",
            "description": "Get tiles from a specific dashboard",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dashboard_id": {
                        "type": "string",
                        "description": "The dashboard ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "dashboard_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "tiles": {
                        "type": "array",
                        "description": "List of dashboard tiles",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "title": {
                                    "type": ["string", "null"]
                                },
                                "embedUrl": {
                                    "type": ["string", "null"]
                                },
                                "datasetId": {
                                    "type": ["string", "null"]
                                },
                                "reportId": {
                                    "type": ["string", "null"]
                                }
                            }
                        }
                    }
                },
                "required": [
                    "tiles"
                ]
            }
        },
        "execute_queries": {
            "display_name": "Execute DAX Queries",
            "description": "Execute DAX queries against a dataset",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    },
                    "queries": {
                        "type": "array",
                        "description": "List of DAX queries to execute",
                        "items": {
                            "type": "object",
                            "properties": {
                                "query": {
                                    "type": "string",
                                    "description": "DAX query string"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "dataset_id",
                    "queries"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "results": {
                        "type": "array",
                        "description": "Query results"
                    }
                },
                "required": [
                    "results"
                ]
            }
        },
        "get_dataset_schema": {
            "display_name": "Get Dataset Schema",
            "description": "Discover a dataset's table and column names, so create_report's pages/visuals can reference real columns instead of guessing. Tries DAX metadata functions (INFO.TABLES()/INFO.COLUMNS()) first, which only work on newer semantic model formats; if that fails and a workspace_id is given, falls back to the Admin Metadata Scanning API, which works on any dataset format but needs tenant admin API access. If both fail, use clone_report to build on an existing report's dataset bindings instead.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset ID"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The workspace ID (optional, defaults to My workspace)"
                    }
                },
                "required": [
                    "dataset_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "tables": {
                        "type": "array",
                        "description": "Discovered tables, each with a name and its column names",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": ["string", "null"],
                                    "description": "Internal table ID, when available (null when discovered via the admin metadata scan fallback)"
                                },
                                "name": {
                                    "type": "string",
                                    "description": "Table name to use in create_report visuals"
                                },
                                "columns": {
                                    "type": "array",
                                    "description": "Column/measure names in this table",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "columns_available": {
                        "type": "boolean",
                        "description": "False if table names were discovered but column-level metadata was not available"
                    }
                },
                "required": [
                    "tables",
                    "columns_available"
                ]
            }
        },
        "get_report_definition": {
            "display_name": "Get Report Definition",
            "description": "Diagnostic action: fetch the raw report definition file parts of an existing report via the Fabric getDefinition API - useful for inspecting the exact package format a tenant's Report Workload expects when create_report's generated package is rejected. The exact parts returned vary by report format: confirmed live that some tenants use only 3 files (.platform, definition.pbir, report.json with everything inlined), while Microsoft's public PBIR docs describe a more decomposed layout (separate version.json/pages/*.json/visuals/*.json) used elsewhere. Don't assume either shape - inspect the actual paths returned.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "report_id": {
                        "type": "string",
                        "description": "The report ID to fetch the definition of"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The Fabric workspace ID the report lives in"
                    }
                },
                "required": [
                    "report_id",
                    "workspace_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "parts": {
                        "type": "array",
                        "description": "Decoded file parts, each with a path and its raw text content",
                        "items": {
                            "type": "object",
                            "properties": {
                                "path": {
                                    "type": "string",
                                    "description": "File path within the report package, e.g. definition/version.json"
                                },
                                "content": {
                                    "type": ["string", "null"],
                                    "description": "Decoded UTF-8 content, or null if it couldn't be decoded as text"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "parts"
                ]
            }
        },
        "create_report": {
            "display_name": "Create Report",
            "description": "Create a new Power BI report in a Fabric workspace bound to an existing dataset. Specify pages and visuals with the columns or measures to display - the report is built and published automatically. Table/column names must match the dataset exactly - use get_dataset_schema first to discover them, or clone_report as a fallback if schema discovery isn't supported for that dataset.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "display_name": {
                        "type": "string",
                        "description": "Name for the new report"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "The Fabric workspace ID where the report will be created"
                    },
                    "dataset_id": {
                        "type": "string",
                        "description": "The dataset (semantic model) ID to bind the report to"
                    },
                    "pages": {
                        "type": "array",
                        "description": "Pages to include in the report",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Display name of the page"
                                },
                                "visuals": {
                                    "type": "array",
                                    "description": "Visuals to place on this page",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "type": {
                                                "type": "string",
                                                "description": "Visual type: table, bar, line, card, pie, column, scatter, area, donut, matrix",
                                                "enum": [
                                                    "table",
                                                    "bar",
                                                    "line",
                                                    "card",
                                                    "pie",
                                                    "column",
                                                    "scatter",
                                                    "area",
                                                    "donut",
                                                    "matrix"
                                                ]
                                            },
                                            "title": {
                                                "type": "string",
                                                "description": "Visual title displayed above the chart"
                                            },
                                            "table": {
                                                "type": "string",
                                                "description": "Source table name in the dataset"
                                            },
                                            "columns": {
                                                "type": "array",
                                                "description": "Column or measure names to include. For charts: first item is the category axis, remaining items are Y-axis measures. Must be non-empty - an empty list silently produces a blank visual with no data bound to it.",
                                                "items": {
                                                    "type": "string"
                                                },
                                                "minItems": 1
                                            },
                                            "x": {
                                                "type": "number",
                                                "description": "X position in pixels (optional, auto-laid out if omitted)"
                                            },
                                            "y": {
                                                "type": "number",
                                                "description": "Y position in pixels (optional, auto-laid out if omitted)"
                                            },
                                            "width": {
                                                "type": "number",
                                                "description": "Width in pixels (default 600)"
                                            },
                                            "height": {
                                                "type": "number",
                                                "description": "Height in pixels (default 350)"
                                            }
                                        },
                                        "required": [
                                            "type",
                                            "table",
                                            "columns"
                                        ]
                                    }
                                }
                            },
                            "required": [
                                "name",
                                "visuals"
                            ]
                        }
                    }
                },
                "required": [
                    "display_name",
                    "workspace_id",
                    "dataset_id",
                    "pages"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "ID of the created report"
                    },
                    "display_name": {
                        "type": "string",
                        "description": "Name of the created report"
                    },
                    "workspace_id": {
                        "type": "string",
                        "description": "Workspace ID where the report was created"
                    },
                    "web_url": {
                        "type": "string",
                        "description": "URL to open the report in Power BI"
                    }
                },
                "required": [
                    "id",
                    "display_name",
                    "workspace_id",
                    "web_url"
                ]
            }
        }
    },
    "display_name": "Power BI"
}
