{
    "name": "LinkedIn",
    "version": "3.0.0",
    "description": "Comprehensive LinkedIn integration for content sharing, post management, comments, and reactions using API version 202601.",
    "entry_point": "linkedin.py",
    "auth": {
        "type": "platform",
        "provider": "linkedin",
        "scopes": [
            "w_member_social",
            "openid",
            "profile",
            "email"
        ]
    },
    "actions": {
        "get_user_info": {
            "display_name": "Get User Info",
            "description": "Retrieve profile information for the authenticated LinkedIn user using OpenID Connect.",
            "input_schema": {
                "type": "object",
                "properties": {},
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Status of the user info retrieval operation."
                    },
                    "user_info": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "User profile information following OpenID Connect standard claims.",
                        "properties": {
                            "sub": {
                                "type": "string",
                                "description": "Subject identifier - unique LinkedIn user ID."
                            },
                            "name": {
                                "type": "string",
                                "description": "Full name of the user."
                            },
                            "given_name": {
                                "type": "string",
                                "description": "First name of the user."
                            },
                            "family_name": {
                                "type": "string",
                                "description": "Last name of the user."
                            },
                            "picture": {
                                "type": "string",
                                "description": "URL of the user's profile picture."
                            },
                            "locale": {
                                "type": "object",
                                "description": "User's locale information.",
                                "properties": {
                                    "country": {
                                        "type": "string",
                                        "description": "Country code (e.g., US)."
                                    },
                                    "language": {
                                        "type": "string",
                                        "description": "Language code (e.g., en)."
                                    }
                                }
                            },
                            "email": {
                                "type": "string",
                                "description": "User's primary email address (if email scope granted)."
                            },
                            "email_verified": {
                                "type": "boolean",
                                "description": "Whether the email has been verified."
                            }
                        }
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "create_post": {
            "display_name": "Create Post",
            "description": "Create a LinkedIn post with optional images. Supports text-only posts, single image posts, and multi-image posts (up to 20 images). This is the recommended action for creating posts with images.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "text": {
                        "type": "string",
                        "description": "The text content/commentary for the post. Optional if images are provided."
                    },
                    "file": {
                        "type": "object",
                        "description": "Single file object for the post image.",
                        "properties": {
                            "content": {
                                "type": "string",
                                "description": "Base64-encoded file content"
                            },
                            "name": {
                                "type": "string",
                                "description": "Filename"
                            },
                            "contentType": {
                                "type": "string",
                                "description": "MIME type (image/jpeg, image/png, image/gif)"
                            }
                        },
                        "required": [
                            "content",
                            "name",
                            "contentType"
                        ]
                    },
                    "files": {
                        "type": "array",
                        "description": "Array of file objects for multi-image posts (up to 20 images).",
                        "items": {
                            "type": "object",
                            "properties": {
                                "content": {
                                    "type": "string",
                                    "description": "Base64-encoded file content"
                                },
                                "name": {
                                    "type": "string",
                                    "description": "Filename"
                                },
                                "contentType": {
                                    "type": "string",
                                    "description": "MIME type (image/jpeg, image/png, image/gif)"
                                }
                            },
                            "required": [
                                "content",
                                "name",
                                "contentType"
                            ]
                        },
                        "maxItems": 20
                    },
                    "visibility": {
                        "type": "string",
                        "enum": [
                            "PUBLIC",
                            "CONNECTIONS"
                        ],
                        "description": "Post visibility. PUBLIC makes it visible to everyone, CONNECTIONS limits to your connections. Defaults to PUBLIC.",
                        "default": "PUBLIC"
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID (sub) for the person posting. If not provided, uses the authenticated user."
                    },
                    "disable_reshare": {
                        "type": "boolean",
                        "description": "If true, prevents others from resharing this post. Defaults to false.",
                        "default": false
                    }
                },
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the post creation action."
                    },
                    "post_id": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "The URN of the created post (e.g., urn:li:share:123456)."
                    },
                    "post_url": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Direct URL to the post on LinkedIn."
                    },
                    "images_uploaded": {
                        "type": "integer",
                        "description": "Number of images successfully uploaded."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "share_article": {
            "display_name": "Share Article",
            "description": "Share an article post on LinkedIn with a URL, title, and description.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "article_url": {
                        "type": "string",
                        "description": "The URL of the article to share."
                    },
                    "article_title": {
                        "type": "string",
                        "description": "The title of the article."
                    },
                    "article_description": {
                        "type": "string",
                        "description": "A description of the article content.",
                        "default": ""
                    },
                    "commentary": {
                        "type": "string",
                        "description": "Optional commentary to add with the article share.",
                        "default": ""
                    },
                    "visibility": {
                        "type": "string",
                        "enum": [
                            "PUBLIC",
                            "CONNECTIONS"
                        ],
                        "description": "Post visibility. Defaults to PUBLIC.",
                        "default": "PUBLIC"
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID for the person posting. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "article_url",
                    "article_title"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the article sharing action."
                    },
                    "post_id": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "The URN of the created post."
                    },
                    "post_url": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Direct URL to the post on LinkedIn."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "reshare_post": {
            "display_name": "Reshare Post",
            "description": "Reshare an existing LinkedIn post with optional commentary.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "original_post_urn": {
                        "type": "string",
                        "description": "The URN of the post to reshare (e.g., urn:li:share:123456 or urn:li:ugcPost:123456)."
                    },
                    "commentary": {
                        "type": "string",
                        "description": "Optional commentary to add with the reshare.",
                        "default": ""
                    },
                    "visibility": {
                        "type": "string",
                        "enum": [
                            "PUBLIC",
                            "CONNECTIONS"
                        ],
                        "description": "Post visibility. Defaults to PUBLIC.",
                        "default": "PUBLIC"
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID for the person resharing. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "original_post_urn"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the reshare action."
                    },
                    "post_id": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "The URN of the created reshare post."
                    },
                    "post_url": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Direct URL to the post on LinkedIn."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "update_post": {
            "display_name": "Update Post",
            "description": "Update the commentary/text of an existing LinkedIn post.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the post to update."
                    },
                    "commentary": {
                        "type": "string",
                        "description": "The new text content for the post."
                    }
                },
                "required": [
                    "post_urn",
                    "commentary"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the update action."
                    },
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the updated post."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "delete_post": {
            "display_name": "Delete Post",
            "description": "Delete a LinkedIn post.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the post to delete."
                    }
                },
                "required": [
                    "post_urn"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the delete action."
                    },
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the deleted post."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "create_comment": {
            "display_name": "Create Comment",
            "description": "Add a comment to a LinkedIn post.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the post to comment on (e.g., urn:li:activity:123456)."
                    },
                    "message": {
                        "type": "string",
                        "description": "The comment text."
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID for the commenter. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "post_urn",
                    "message"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the create comment action."
                    },
                    "comment_id": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "The ID of the created comment."
                    },
                    "comment": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "The full comment data returned by LinkedIn API."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "delete_comment": {
            "display_name": "Delete Comment",
            "description": "Delete a comment from a LinkedIn post.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "post_urn": {
                        "type": "string",
                        "description": "The URN of the post containing the comment."
                    },
                    "comment_id": {
                        "type": "string",
                        "description": "The ID of the comment to delete."
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID of the comment author. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "post_urn",
                    "comment_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the delete comment action."
                    },
                    "comment_id": {
                        "type": "string",
                        "description": "The ID of the deleted comment."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "create_reaction": {
            "display_name": "Create Reaction",
            "description": "Add a reaction to a LinkedIn post or comment.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target_urn": {
                        "type": "string",
                        "description": "The URN of the post or comment to react to (e.g., urn:li:activity:123456)."
                    },
                    "reaction_type": {
                        "type": "string",
                        "enum": [
                            "LIKE",
                            "PRAISE",
                            "EMPATHY",
                            "INTEREST",
                            "APPRECIATION",
                            "ENTERTAINMENT"
                        ],
                        "description": "The type of reaction. LIKE=Like, PRAISE=Celebrate, EMPATHY=Love, INTEREST=Insightful, APPRECIATION=Support, ENTERTAINMENT=Funny. Defaults to LIKE.",
                        "default": "LIKE"
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID for the reactor. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "target_urn"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the create reaction action."
                    },
                    "reaction": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "The reaction data returned by LinkedIn API."
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "delete_reaction": {
            "display_name": "Delete Reaction",
            "description": "Remove a reaction from a LinkedIn post or comment.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target_urn": {
                        "type": "string",
                        "description": "The URN of the post or comment to remove reaction from."
                    },
                    "author_id": {
                        "type": "string",
                        "description": "The LinkedIn user ID of the reactor. If not provided, uses the authenticated user."
                    }
                },
                "required": [
                    "target_urn"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "string",
                        "description": "Result of the delete reaction action."
                    },
                    "target_urn": {
                        "type": "string",
                        "description": "The URN of the target."
                    }
                },
                "required": [
                    "result"
                ]
            }
        }
    },
    "display_name": "LinkedIn"
}
