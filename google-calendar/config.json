{
    "name": "Google Calendar",
    "display_name": "Google Calendar",
    "version": "1.0.1",
    "description": "Google Calendar integration for managing calendars, events, and recurring event instances.",
    "entry_point": "google_calendar.py",
    "auth": {
        "type": "platform",
        "provider": "Google Calendar",
        "scopes": ["https://www.googleapis.com/auth/calendar"]
    },
    "actions": {
        "list_calendars": {
            "display_name": "List Calendars",
            "description": "List all Google calendars accessible to the authenticated user.",
            "input_schema": {
                "type": "object",
                "properties": {},
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "calendars": {
                        "type": "array",
                        "description": "List of calendars the user has access to",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Unique calendar ID"
                                },
                                "summary": {
                                    "type": "string",
                                    "description": "Calendar display name"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "Calendar description"
                                },
                                "primary": {
                                    "type": "boolean",
                                    "description": "True if this is the user's primary calendar"
                                },
                                "accessRole": {
                                    "type": "string",
                                    "description": "User's access role for this calendar (e.g. owner, reader)"
                                }
                            },
                            "required": ["id", "summary"]
                        }
                    }
                },
                "required": ["calendars"]
            }
        },
        "list_events": {
            "display_name": "List Events",
            "description": "List events from a Google Calendar. Recurring event instances are automatically expanded so each occurrence is returned individually. Results are paginated.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "calendar_id": {
                        "type": "string",
                        "description": "Google Calendar ID to list events from. Use 'primary' for the user's primary calendar."
                    },
                    "time_min": {
                        "type": "string",
                        "description": "Lower bound (exclusive) for an event's end time in RFC3339 format (e.g. '2026-06-01T00:00:00Z'). Events whose end time is after this value are returned, including long events that started before it."
                    },
                    "time_max": {
                        "type": "string",
                        "description": "Upper bound (exclusive) for an event's start time in RFC3339 format (e.g. '2026-06-30T23:59:59Z')"
                    },
                    "max_results": {
                        "type": "integer",
                        "description": "Maximum number of events to return per page (1–2500, default 250)"
                    },
                    "page_token": {
                        "type": "string",
                        "description": "Token from a previous response's nextPageToken to fetch the next page of results"
                    },
                    "query": {
                        "type": "string",
                        "description": "Free-text search query to filter events by title, description, or location"
                    }
                },
                "required": ["calendar_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "events": {
                        "type": "array",
                        "description": "List of calendar events, including individual instances of recurring events",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Event ID (for recurring instances this is unique per occurrence)"
                                },
                                "summary": {
                                    "type": "string",
                                    "description": "Event title"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "Event description"
                                },
                                "start": {
                                    "type": "object",
                                    "description": "Event start time",
                                    "properties": {
                                        "dateTime": {
                                            "type": "string",
                                            "description": "Start date-time in RFC3339 format (for timed events)"
                                        },
                                        "date": {
                                            "type": "string",
                                            "description": "Start date in YYYY-MM-DD format (for all-day events)"
                                        }
                                    }
                                },
                                "end": {
                                    "type": "object",
                                    "description": "Event end time",
                                    "properties": {
                                        "dateTime": {
                                            "type": "string",
                                            "description": "End date-time in RFC3339 format (for timed events)"
                                        },
                                        "date": {
                                            "type": "string",
                                            "description": "End date in YYYY-MM-DD format (for all-day events)"
                                        }
                                    }
                                },
                                "location": {
                                    "type": "string",
                                    "description": "Event location"
                                },
                                "attendees": {
                                    "type": "array",
                                    "description": "List of event attendees",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "email": {"type": "string", "description": "Attendee email address"},
                                            "displayName": {"type": "string", "description": "Attendee display name"},
                                            "responseStatus": {"type": "string", "description": "Attendee RSVP status (accepted, declined, tentative, needsAction)"}
                                        }
                                    }
                                },
                                "recurringEventId": {
                                    "type": "string",
                                    "description": "ID of the parent recurring event (present on instances of recurring events)"
                                }
                            },
                            "required": ["id", "summary"]
                        }
                    },
                    "nextPageToken": {
                        "type": "string",
                        "description": "Token to retrieve the next page of results; absent when this is the last page"
                    }
                },
                "required": ["events"]
            }
        },
        "get_event": {
            "display_name": "Get Event",
            "description": "Get details of a specific Google Calendar event by its ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "calendar_id": {
                        "type": "string",
                        "description": "Calendar ID containing the event. Use 'primary' for the user's primary calendar."
                    },
                    "event_id": {
                        "type": "string",
                        "description": "The unique ID of the event to retrieve"
                    }
                },
                "required": ["calendar_id", "event_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "event": {
                        "type": "object",
                        "description": "Full details of the requested calendar event",
                        "properties": {
                            "id": {"type": "string", "description": "Event ID"},
                            "summary": {"type": "string", "description": "Event title"},
                            "description": {"type": "string", "description": "Event description"},
                            "location": {"type": "string", "description": "Event location"},
                            "start": {
                                "type": "object",
                                "description": "Event start time",
                                "properties": {
                                    "dateTime": {"type": "string", "description": "Start date-time (RFC3339)"},
                                    "date": {"type": "string", "description": "Start date for all-day events (YYYY-MM-DD)"}
                                }
                            },
                            "end": {
                                "type": "object",
                                "description": "Event end time",
                                "properties": {
                                    "dateTime": {"type": "string", "description": "End date-time (RFC3339)"},
                                    "date": {"type": "string", "description": "End date for all-day events (YYYY-MM-DD)"}
                                }
                            },
                            "attendees": {
                                "type": "array",
                                "description": "Event attendees",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "email": {"type": "string", "description": "Attendee email"},
                                        "displayName": {"type": "string", "description": "Attendee display name"},
                                        "responseStatus": {"type": "string", "description": "RSVP status"}
                                    }
                                }
                            },
                            "created": {"type": "string", "description": "Event creation time (RFC3339)"},
                            "updated": {"type": "string", "description": "Event last modification time (RFC3339)"},
                            "htmlLink": {"type": "string", "description": "URL to view the event in Google Calendar"}
                        },
                        "required": ["id", "summary"]
                    }
                },
                "required": ["event"]
            }
        },
        "create_event": {
            "display_name": "Create Event",
            "description": "Create a new event on a Google Calendar.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "calendar_id": {
                        "type": "string",
                        "description": "Calendar ID to create the event in. Use 'primary' for the user's primary calendar."
                    },
                    "summary": {
                        "type": "string",
                        "description": "Event title"
                    },
                    "description": {
                        "type": "string",
                        "description": "Event description or notes"
                    },
                    "start_datetime": {
                        "type": "string",
                        "description": "Event start date-time in RFC3339 format (e.g. '2026-06-10T10:00:00'). Use with end_datetime for timed events."
                    },
                    "end_datetime": {
                        "type": "string",
                        "description": "Event end date-time in RFC3339 format (e.g. '2026-06-10T11:00:00'). Use with start_datetime for timed events."
                    },
                    "start_date": {
                        "type": "string",
                        "description": "Event start date in YYYY-MM-DD format. Use with end_date for all-day events."
                    },
                    "end_date": {
                        "type": "string",
                        "description": "Event end date in YYYY-MM-DD format (exclusive). For a single-day event on 2026-06-15, pass '2026-06-16'. Use with start_date for all-day events."
                    },
                    "location": {
                        "type": "string",
                        "description": "Event location (address, room name, or video link)"
                    },
                    "attendees": {
                        "type": "array",
                        "description": "List of attendee email addresses to invite to the event",
                        "items": {
                            "type": "string",
                            "description": "Attendee email address"
                        }
                    },
                    "timezone": {
                        "type": "string",
                        "description": "IANA timezone name for the event (e.g. 'Pacific/Auckland', 'America/New_York'). Defaults to UTC."
                    }
                },
                "required": ["calendar_id", "summary"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "event": {
                        "type": "object",
                        "description": "The newly created event",
                        "properties": {
                            "id": {"type": "string", "description": "Event ID assigned by Google Calendar"},
                            "summary": {"type": "string", "description": "Event title"},
                            "htmlLink": {"type": "string", "description": "URL to view the event in Google Calendar"}
                        },
                        "required": ["id", "summary"]
                    }
                },
                "required": ["event"]
            }
        },
        "update_event": {
            "display_name": "Update Event",
            "description": "Update an existing Google Calendar event. Only provided fields are changed; all other fields are preserved.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "calendar_id": {
                        "type": "string",
                        "description": "Calendar ID containing the event. Use 'primary' for the user's primary calendar."
                    },
                    "event_id": {
                        "type": "string",
                        "description": "The unique ID of the event to update"
                    },
                    "summary": {
                        "type": "string",
                        "description": "New event title"
                    },
                    "description": {
                        "type": "string",
                        "description": "New event description or notes"
                    },
                    "start_datetime": {
                        "type": "string",
                        "description": "New event start date-time in RFC3339 format. Use with end_datetime."
                    },
                    "end_datetime": {
                        "type": "string",
                        "description": "New event end date-time in RFC3339 format. Use with start_datetime."
                    },
                    "start_date": {
                        "type": "string",
                        "description": "New event start date in YYYY-MM-DD format for all-day events. Use with end_date."
                    },
                    "end_date": {
                        "type": "string",
                        "description": "New event end date in YYYY-MM-DD format (exclusive). For a single-day event on 2026-06-15, pass '2026-06-16'. Use with start_date for all-day events."
                    },
                    "location": {
                        "type": "string",
                        "description": "New event location"
                    },
                    "attendees": {
                        "type": "array",
                        "description": "Updated list of attendee email addresses (replaces all existing attendees; pass empty array to remove all)",
                        "items": {
                            "type": "string",
                            "description": "Attendee email address"
                        }
                    },
                    "timezone": {
                        "type": "string",
                        "description": "IANA timezone name for the event (e.g. 'Pacific/Auckland'). Defaults to the event's existing timezone."
                    }
                },
                "required": ["calendar_id", "event_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "event": {
                        "type": "object",
                        "description": "The updated event details",
                        "properties": {
                            "id": {"type": "string", "description": "Event ID"},
                            "summary": {"type": "string", "description": "Event title"},
                            "updated": {"type": "string", "description": "Last modification time (RFC3339)"}
                        },
                        "required": ["id", "summary"]
                    }
                },
                "required": ["event"]
            }
        },
        "delete_event": {
            "display_name": "Delete Event",
            "description": "Permanently delete a Google Calendar event by its ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "calendar_id": {
                        "type": "string",
                        "description": "Calendar ID containing the event. Use 'primary' for the user's primary calendar."
                    },
                    "event_id": {
                        "type": "string",
                        "description": "The unique ID of the event to delete"
                    }
                },
                "required": ["calendar_id", "event_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "deleted": {
                        "type": "boolean",
                        "description": "True when the event was successfully deleted"
                    }
                },
                "required": ["deleted"]
            }
        }
    }
}
