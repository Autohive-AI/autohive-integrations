            "type": "string",
            "description": "The updated name of the job."
          },
          "description": {
            "type": "string",
            "description": "The updated description of the job."
          },
          "start_date": {
            "type": "string",
            "description": "The updated start date (ISO 8601 format)."
          },
          "due_date": {
            "type": "string",
            "description": "The updated due date (ISO 8601 format)."
          },
          "state": {
            "type": "string",
            "description": "The updated status of the job (e.g. 'Active', 'Completed')."
          }
        },
        "required": ["identifier"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "job": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
