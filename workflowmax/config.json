        },
        "required": ["name", "client_uuid"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "job": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
    "update_job": {
