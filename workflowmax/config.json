        "required": ["client_uuid"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "contacts": {"type": "array", "items": {"type": "object"}},
          "error": {"type": "string"}
        }
      }
    },
