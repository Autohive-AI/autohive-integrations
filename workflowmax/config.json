        "required": ["uuid"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "client": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
    "list_client_contacts": {
      "display_name": "List Client Contacts",
      "description": "List all contacts for a specific client.",
