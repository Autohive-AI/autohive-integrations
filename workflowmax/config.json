        "type": "object",
        "properties": {
          "client_uuid": {
            "type": "string",
            "description": "The UUID of the client to add the contact to."
          },
          "name": {
            "type": "string",
            "description": "The full name of the contact."
          },
          "email": {
            "type": "string",
            "description": "The email address of the contact."
          },
          "phone": {
            "type": "string",
            "description": "The phone number of the contact."
