{
  "name": "WorkflowMax",
  "display_name": "WorkflowMax",
  "version": "1.0.0",
  "description": "WorkflowMax integration for managing clients, jobs, timesheets, invoices, quotes, tasks, staff, leads, costs, and purchase orders.",
  "entry_point": "workflowmax.py",
  "auth": {
    "type": "platform",
    "provider": "workflowmax",
    "scopes": [
      "openid",
      "profile",
      "email",
      "workflowmax",
      "offline_access"
    ]
  },
  "actions": {
    "list_clients": {
      "display_name": "List Clients",
      "description": "List all clients in WorkflowMax.",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Page number for pagination (1-based)."
          },
          "page_size": {
            "type": "integer",
            "description": "Number of results per page."
          }
        },
        "required": []
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "clients": {"type": "array", "items": {"type": "object"}},
          "error": {"type": "string"}
        }
      }
    },
    "get_client": {
      "display_name": "Get Client",
      "description": "Get a client by their UUID.",
      "input_schema": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "The UUID of the client to retrieve."
          }
        },
        "required": ["uuid"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "client": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
    "create_client": {
      "display_name": "Create Client",
      "description": "Create a new client in WorkflowMax.",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the client."
          },
          "email": {
            "type": "string",
            "description": "The email address of the client."
          },
          "phone": {
            "type": "string",
            "description": "The phone number of the client."
          },
          "address": {
            "type": "string",
            "description": "The street address of the client."
          },
          "city": {
            "type": "string",
            "description": "The city of the client."
          },
          "region": {
            "type": "string",
            "description": "The region or state of the client."
          },
          "country": {
            "type": "string",
            "description": "The country of the client."
          },
          "postal_code": {
            "type": "string",
            "description": "The postal/zip code of the client."
          }
        },
        "required": ["name"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "client": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
    "update_client": {
      "display_name": "Update Client",
      "description": "Update an existing client in WorkflowMax.",
      "input_schema": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "The UUID of the client to update."
          },
          "name": {
            "type": "string",
            "description": "The updated name of the client."
          },
          "email": {
            "type": "string",
            "description": "The updated email address."
          },
          "phone": {
            "type": "string",
            "description": "The updated phone number."
          },
          "address": {
            "type": "string",
            "description": "The updated street address."
          },
          "city": {
            "type": "string",
            "description": "The updated city."
          },
          "region": {
            "type": "string",
            "description": "The updated region or state."
          },
          "country": {
            "type": "string",
            "description": "The updated country."
          },
          "postal_code": {
            "type": "string",
            "description": "The updated postal/zip code."
          }
