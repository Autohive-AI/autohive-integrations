    "add_timesheet": {
      "display_name": "Add Timesheet",
      "description": "Log a timesheet entry against a job and task.",
      "input_schema": {
        "type": "object",
        "properties": {
          "job_uuid": {
            "type": "string",
            "description": "The UUID of the job to log time against."
