          "task_uuid": {
            "type": "string",
            "description": "The UUID of the task to log time against."
          },
          "staff_uuid": {
            "type": "string",
            "description": "The UUID of the staff member logging time."
          },
          "minutes": {
            "type": "integer",
            "description": "The number of minutes to log."
          },
          "date": {
            "type": "string",
            "description": "The date of the time entry (ISO 8601 format)."
          },
          "note": {
            "type": "string",
            "description": "An optional note for the time entry."
          }
        },
        "required": ["job_uuid", "task_uuid", "staff_uuid", "minutes", "date"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "timesheet": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
