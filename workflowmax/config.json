        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the job."
          },
          "client_uuid": {
            "type": "string",
            "description": "The UUID of the client this job belongs to."
          },
          "description": {
            "type": "string",
            "description": "A description of the job."
          },
          "start_date": {
            "type": "string",
            "description": "The start date of the job (ISO 8601 format)."
          },
          "due_date": {
            "type": "string",
            "description": "The due date of the job (ISO 8601 format)."
