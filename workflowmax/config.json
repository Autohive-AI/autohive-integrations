      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Page number for pagination (1-based)."
          },
          "page_size": {
            "type": "integer",
            "description": "Number of results per page."
          },
          "last_modified": {
            "type": "string",
            "description": "Filter jobs modified after this ISO 8601 timestamp."
          }
        },
        "required": []
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result": {"type": "boolean"},
          "jobs": {"type": "array", "items": {"type": "object"}},
          "error": {"type": "string"}
        }
      }
    },
    "get_job": {
      "display_name": "Get Job",
      "description": "Get a job by its identifier (UUID or job number).",
      "input_schema": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "The UUID or job number of the job to retrieve."
