# ============================================================================
# Autohive Integrations - environment variables for integration tests
# ============================================================================
#
# Copy this file to .env and fill in values for the integrations you need
# to test against live APIs.  The .env file is gitignored.
#
# Unit tests (pytest -m unit) never need these - they use mocks.
# Integration tests (pytest -m integration) will skip if the required
# variable is missing.
#
# Format: VARIABLE_NAME=value  (no quotes needed)
# ============================================================================

# -- ActiveCampaign --
# ACTIVECAMPAIGN_API_KEY=
# ACTIVECAMPAIGN_API_URL=
# Optional - targets specific resources for faster tests
# ACTIVECAMPAIGN_TEST_CAMPAIGN_ID=
# ACTIVECAMPAIGN_TEST_CONTACT_ID=

# -- App Business Reviews --
# APP_BUSINESS_REVIEWS_API_KEY=

# -- Asana --
# ASANA_ACCESS_TOKEN=
# ASANA_TEST_WORKSPACE_GID=
# ASANA_TEST_PROJECT_GID=
# ASANA_TEST_TASK_GID=

# -- AWS --
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# Optional - STS temporary credentials
# AWS_SESSION_TOKEN=
# Optional - needed for GuardDuty tests
# AWS_DETECTOR_ID=
# Optional - needed for CloudTrail tests
# AWS_TRAIL_NAME=
# Optional - needed for CloudWatch Logs tests
# AWS_LOG_GROUP=
# AWS_LOG_STREAM=
# Optional - needed for CloudWatch alarm tests
# AWS_ALARM_NAME=
# Optional - needed for Security Hub finding tests
# AWS_FINDING_ARN=



# -- Bitly --
# BITLY_ACCESS_TOKEN=

# -- Box --
# BOX_ACCESS_TOKEN=

# -- Calendly --
# OAuth/personal access token for Calendly API v2 read-only integration tests.
# The destructive webhook lifecycle test also needs a paid Calendly plan.
# CALENDLY_ACCESS_TOKEN=

# -- Canva --
# OAuth2 access token with the scopes declared in canva/config.json
# CANVA_ACCESS_TOKEN=

# -- Circle --
# CIRCLE_API_TOKEN=
# Optional - target specific resources for integration tests
# CIRCLE_TEST_POST_ID=
# CIRCLE_TEST_SPACE_ID=
# CIRCLE_TEST_MEMBER_ID=
# CIRCLE_TEST_MEMBER_EMAIL=



# -- ClickUp --
# CLICKUP_ACCESS_TOKEN=

# -- Coda --
# CODA_API_KEY=

# -- Dropbox --
# DROPBOX_ACCESS_TOKEN=
# Optional: parent folder for destructive integration tests (default: /autohive_integration_test)
# DROPBOX_TEST_FOLDER=

# -- Fergus --
# FERGUS_API_TOKEN=
# Optional - pin to specific resources for targeted integration tests
# FERGUS_TEST_JOB_ID=
# FERGUS_TEST_CUSTOMER_ID=
# FERGUS_TEST_SITE_ID=

# -- Float --
# FLOAT_API_KEY=

# -- Freshdesk --
# FRESHDESK_API_KEY=
# FRESHDESK_DOMAIN=

# -- Front --
# FRONT_ACCESS_TOKEN=

# -- Ghost --
# GHOST_API_URL=
# GHOST_CONTENT_API_KEY=
# GHOST_ADMIN_API_KEY=
# Optional â€” target specific resources for integration tests
# GHOST_TEST_POST_ID=
# GHOST_TEST_POST_UPDATED_AT=
# GHOST_TEST_NEWSLETTER_SLUG=
# GHOST_TEST_MEMBER_ID=

# -- GitHub --
# OAuth2 access token for read-only integration tests.
# GITHUB_ACCESS_TOKEN=

# -- Gmail --
# Required for read-only and destructive integration tests.
# Token must have the https://www.googleapis.com/auth/gmail.modify scope.
# GMAIL_ACCESS_TOKEN=
# Optional - pin to a specific thread/message for the reply test.
# Otherwise the test picks the most-recent inbox message dynamically.
# GMAIL_TEST_THREAD_ID=
# GMAIL_TEST_MESSAGE_ID=

# -- Gong --
# GONG_ACCESS_TOKEN=
# GONG_API_BASE_URL=

# -- Gong --
# GONG_ACCESS_KEY=
# GONG_ACCESS_KEY_SECRET=

# -- Google BigQuery --
# OAuth2 access token with scope: https://www.googleapis.com/auth/bigquery
# BIGQUERY_ACCESS_TOKEN=
# A Google Cloud project ID you can query/write to
# BIGQUERY_PROJECT_ID=

# -- Google Calendar --
# OAuth2 access token with scope: https://www.googleapis.com/auth/calendar
# GOOGLE_CALENDAR_ACCESS_TOKEN=

# -- Google Forms --
# OAuth2 access token with scopes: forms.body, forms.responses.readonly
# GOOGLE_FORMS_ACCESS_TOKEN=
# Optional pre-existing form ID for read-only integration tests
# GOOGLE_FORMS_TEST_FORM_ID=

# -- Google Looker --
# LOOKER_BASE_URL=
# LOOKER_CLIENT_ID=
# LOOKER_CLIENT_SECRET=
# LOOKER_TEST_DASHBOARD_ID=
# LOOKER_TEST_MODEL_NAME=

# -- Google Search Console --
# OAuth2 access token with scope: https://www.googleapis.com/auth/webmasters
# GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
# Optional - a verified site URL (e.g. https://example.com or sc-domain:example.com)
# GOOGLE_SEARCH_CONSOLE_TEST_SITE_URL=

# -- Google Sheets --
# GOOGLE_SHEETS_ACCESS_TOKEN=
# GOOGLE_SHEETS_TEST_SPREADSHEET_ID=

# -- Harvest --
# HARVEST_ACCESS_TOKEN=
# HARVEST_ACCOUNT_ID=

# -- HubSpot --
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_TEST_CONTACT_ID=
# HUBSPOT_TEST_CONTACT_EMAIL=
# HUBSPOT_TEST_COMPANY_ID=
# HUBSPOT_TEST_DEAL_ID=
# HUBSPOT_TEST_TICKET_ID=
# HUBSPOT_TEST_LIST_ID=
# HUBSPOT_TEST_NOTE_ID=
# HUBSPOT_TEST_OWNER_ID=

# -- LinkedIn --
# LINKEDIN_ACCESS_TOKEN=

# -- Mailchimp --
# Platform OAuth access token for the Mailchimp API.
# MAILCHIMP_ACCESS_TOKEN=
# Mailchimp data center code (e.g. us19) — visible in your Mailchimp account URL.
# MAILCHIMP_DC=
# Optional — pin to a specific list for targeted member/list integration tests.
# MAILCHIMP_TEST_LIST_ID=
# Optional — pin to a specific campaign for get_campaign read tests.
# MAILCHIMP_TEST_CAMPAIGN_ID=

# -- Lumin PDF --
# LUMIN_PDF_TOKEN=

# -- Microsoft 365 --
# MICROSOFT365_ACCESS_TOKEN=
# MICROSOFT365_TEST_RECIPIENT_EMAIL=   # email address to use as recipient in destructive send/draft/forward tests
# MICROSOFT365_TEST_ATTENDEE_EMAIL=    # email address to use as attendee in find_meeting_times live test
# MICROSOFT365_TEST_SCHEDULE_EMAIL=    # email address to use in get_schedule live test (e.g. user@tenant.onmicrosoft.com)

# -- Notion --
# NOTION_ACCESS_TOKEN=

# -- NZBN --
# NZBN_CLIENT_ID=
# NZBN_CLIENT_SECRET=
# NZBN_SUBSCRIPTION_KEY=

# -- Perplexity --
# PERPLEXITY_API_KEY=

# -- Salesforce --
# SALESFORCE_ACCESS_TOKEN=
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_TEST_RECORD_ID=
# SALESFORCE_TEST_TASK_ID=
# SALESFORCE_TEST_EVENT_ID=

# -- Shopify Customer --
# SHOPIFY_CUSTOMER_ACCESS_TOKEN=
# SHOPIFY_CUSTOMER_SHOP_URL=

# -- Stripe --
# STRIPE_TEST_API_KEY=

# -- Supabase --
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TEST_TABLE=
# SUPABASE_TEST_FUNCTION=
# SUPABASE_TEST_DELETE_USER_ID=



# -- Substack --
# Optional: publication URL used by Substack live integration tests.
# SUBSTACK_TEST_PUBLICATION_URL=
# Optional: post slug used by Substack get_post live integration tests.
# SUBSTACK_TEST_POST_SLUG=

# -- Supadata --
# SUPADATA_API_KEY=

# -- Trello --
# TRELLO_API_KEY=
# TRELLO_API_TOKEN=

# -- Webcal --
# No auth required - integration tests hit a public iCal feed.
# Optional: override the default public feed used by the live tests.
# WEBCAL_TEST_URL=

# -- WhatsApp Business --
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_RECIPIENT_PHONE=
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANG=
# WHATSAPP_MEDIA_URL=

# -- X (formerly Twitter) --
# OAuth2 user access token with scopes: tweet.read, tweet.write, media.write,
# users.read, follows.read, follows.write, like.read, bookmark.read, bookmark.write, offline.access
# X_ACCESS_TOKEN=
# User id to follow/unfollow in the follow lifecycle destructive test (optional)
# X_TEST_TARGET_USER_ID=

# -- Xero --
# XERO_ACCESS_TOKEN=
# XERO_TENANT_ID=

# -- YouTube --
# OAuth2 access token with scopes: youtube, youtube.upload, youtube.force-ssl
# YOUTUBE_ACCESS_TOKEN=
# Existing public video ID (used by read-only tests and as mutation target for update_video)
# YOUTUBE_TEST_VIDEO_ID=
# Existing channel ID (for get_channel and list_playlists read tests)
# YOUTUBE_TEST_CHANNEL_ID=
# Existing playlist ID (for list_playlist_items)
# YOUTUBE_TEST_PLAYLIST_ID=
# Existing top-level comment ID (for list_comment_replies)
# YOUTUBE_TEST_COMMENT_ID=
# Local path to a JPEG/PNG file (used by upload_thumbnail destructive test)
# YOUTUBE_TEST_THUMBNAIL_PATH=
# Video ID owned by the authenticated user (required by moderate_comment, which only works on your own channel)
# YOUTUBE_TEST_OWNED_VIDEO_ID=

# -- Monday.com --
# OAuth access token for Monday.com API integration tests.
# MONDAY_ACCESS_TOKEN=
# Optional: existing board ID for read tests and destructive lifecycle (required for destructive tests).
# MONDAY_TEST_BOARD_ID=

# -- Missive --
# MISSIVE_API_TOKEN=
# Optional - needed for analytics tests (organization ID from Missive settings)
# MISSIVE_ORG_ID=
# Optional - email address used as recipient in destructive draft/message tests
# MISSIVE_TEST_EMAIL=

# -- Zoho CRM --
# OAuth access token for Zoho CRM API v8 integration tests.
# ZOHO_ACCESS_TOKEN=
# Datacenter-specific API domain (default: https://www.zohoapis.com).
# Use the domain that matches your account's region, e.g. https://www.zohoapis.com.au
# ZOHO_API_DOMAIN=
# -- Zoom --
# ZOOM_ACCESS_TOKEN=

# -- Typeform --
# Platform OAuth access token for the Typeform API (read/write scopes).
# TYPEFORM_ACCESS_TOKEN=
# Optional: existing form ID for read tests (falls back to list_forms if unset).
# TYPEFORM_TEST_FORM_ID=
# Optional: existing workspace ID for get_workspace (falls back to list_workspaces if unset).
# TYPEFORM_TEST_WORKSPACE_ID=

# -- ProjectWorks --
# API-account credentials (Admin -> API Accounts -> Details). Used as HTTP Basic username/password.
# PROJECTWORKS_CONSUMER_KEY=
# PROJECTWORKS_CONSUMER_SECRET=
# Optional: existing IDs for get_* read tests (fall back to list_* chaining if unset).
# PROJECTWORKS_TEST_USER_ID=
# PROJECTWORKS_TEST_PROJECT_ID=
# PROJECTWORKS_TEST_CLIENT_ID=

# -- Netlify --
# Personal access token for the Netlify API.
# NETLIFY_ACCESS_TOKEN=
