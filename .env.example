# ============================================================================
# Autohive Integrations ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â environment variables for integration tests
# ============================================================================
#
# Copy this file to .env and fill in values for the integrations you need
# to test against live APIs.  The .env file is gitignored.
#
# Unit tests (pytest -m unit) never need these ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â they use mocks.
# Integration tests (pytest -m integration) will skip if the required
# variable is missing.
#
# Format: VARIABLE_NAME=value  (no quotes needed)
# ============================================================================

# -- ActiveCampaign --
# ACTIVECAMPAIGN_API_KEY=
# ACTIVECAMPAIGN_API_URL=
# Optional ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â targets specific resources for faster tests
# ACTIVECAMPAIGN_TEST_CAMPAIGN_ID=
# ACTIVECAMPAIGN_TEST_CONTACT_ID=

# -- App Business Reviews --
# APP_BUSINESS_REVIEWS_API_KEY=

# -- Bitly --
# BITLY_ACCESS_TOKEN=

# -- Box --
# BOX_ACCESS_TOKEN=

# -- ClickUp --
# CLICKUP_ACCESS_TOKEN=

# -- Coda --
# CODA_API_KEY=

# -- Float --
# FLOAT_API_KEY=

# -- Freshdesk --
# FRESHDESK_API_KEY=
# FRESHDESK_DOMAIN=

# -- Front --
# FRONT_ACCESS_TOKEN=

# -- GitHub --
# OAuth2 access token for read-only integration tests.
# GITHUB_ACCESS_TOKEN=

# -- Gmail --
# Required for read-only and destructive integration tests.
# Token must have the https://www.googleapis.com/auth/gmail.modify scope.
# GMAIL_ACCESS_TOKEN=
# Optional ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â pin to a specific thread/message for the reply test.
# Otherwise the test picks the most-recent inbox message dynamically.
# GMAIL_TEST_THREAD_ID=
# GMAIL_TEST_MESSAGE_ID=

# -- Gong --
# GONG_ACCESS_TOKEN=
# GONG_API_BASE_URL=

# -- Gong --
# GONG_ACCESS_KEY=
# GONG_ACCESS_KEY_SECRET=

# -- Google Calendar --
# OAuth2 access token with scope: https://www.googleapis.com/auth/calendar
# GOOGLE_CALENDAR_ACCESS_TOKEN=

# -- Google Forms --
# OAuth2 access token with scopes: forms.body, forms.responses.readonly
# GOOGLE_FORMS_ACCESS_TOKEN=
# Optional pre-existing form ID for read-only integration tests
# GOOGLE_FORMS_TEST_FORM_ID=

# -- Google Looker --
# LOOKER_BASE_URL=
# LOOKER_CLIENT_ID=
# LOOKER_CLIENT_SECRET=
# LOOKER_TEST_DASHBOARD_ID=
# LOOKER_TEST_MODEL_NAME=

# -- Google Sheets --
# GOOGLE_SHEETS_ACCESS_TOKEN=
# GOOGLE_SHEETS_TEST_SPREADSHEET_ID=

# -- Harvest --
# HARVEST_ACCESS_TOKEN=
# HARVEST_ACCOUNT_ID=

# -- HubSpot --
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_TEST_CONTACT_ID=
# HUBSPOT_TEST_CONTACT_EMAIL=
# HUBSPOT_TEST_COMPANY_ID=
# HUBSPOT_TEST_DEAL_ID=
# HUBSPOT_TEST_TICKET_ID=
# HUBSPOT_TEST_LIST_ID=
# HUBSPOT_TEST_NOTE_ID=
# HUBSPOT_TEST_OWNER_ID=

# -- LinkedIn --
# LINKEDIN_ACCESS_TOKEN=

# -- Lumin PDF --
# LUMIN_PDF_TOKEN=

# -- Notion --
# NOTION_ACCESS_TOKEN=

# -- NZBN --
# NZBN_CLIENT_ID=
# NZBN_CLIENT_SECRET=
# NZBN_SUBSCRIPTION_KEY=

# -- Perplexity --
# PERPLEXITY_API_KEY=

# -- Salesforce --
# SALESFORCE_ACCESS_TOKEN=
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_TEST_RECORD_ID=
# SALESFORCE_TEST_TASK_ID=
# SALESFORCE_TEST_EVENT_ID=

# -- Shopify Customer --
# SHOPIFY_CUSTOMER_ACCESS_TOKEN=
# SHOPIFY_CUSTOMER_SHOP_URL=

# -- Stripe --
# STRIPE_TEST_API_KEY=

# -- Supabase --
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TEST_TABLE=
# SUPABASE_TEST_FUNCTION=
# SUPABASE_TEST_DELETE_USER_ID=

# -- Supadata --
# SUPADATA_API_KEY=

# -- Trello --
# TRELLO_API_KEY=
# TRELLO_API_TOKEN=

# -- WhatsApp Business --
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_RECIPIENT_PHONE=
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANG=
# WHATSAPP_MEDIA_URL=

# -- Xero --
# XERO_ACCESS_TOKEN=
# XERO_TENANT_ID=

# -- YouTube --
# OAuth2 access token with scopes: youtube, youtube.upload, youtube.force-ssl
# YOUTUBE_ACCESS_TOKEN=
# Existing public video ID (used by read-only tests and as mutation target for update_video)
# YOUTUBE_TEST_VIDEO_ID=
# Existing channel ID (for get_channel and list_playlists read tests)
# YOUTUBE_TEST_CHANNEL_ID=
# Existing playlist ID (for list_playlist_items)
# YOUTUBE_TEST_PLAYLIST_ID=
# Existing top-level comment ID (for list_comment_replies)
# YOUTUBE_TEST_COMMENT_ID=
# Local path to a JPEG/PNG file (used by upload_thumbnail destructive test)
# YOUTUBE_TEST_THUMBNAIL_PATH=
# Video ID owned by the authenticated user (required by moderate_comment, which only works on your own channel)
# YOUTUBE_TEST_OWNED_VIDEO_ID=

# -- Zoom --
# ZOOM_ACCESS_TOKEN=
