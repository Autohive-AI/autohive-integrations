{
    "name": "Trello",
    "display_name": "Trello",
    "version": "2.0.0",
    "description": "Trello integration for managing boards, lists, cards, and team collaboration",
    "entry_point": "trello.py",
    "auth": {
        "type": "custom",
        "title": "Trello API Credentials",
        "fields": {
            "type": "object",
            "properties": {
                "api_key": {
                    "type": "string",
                    "label": "API Key",
                    "help_text": "Your Trello API Key from https://trello.com/power-ups/admin"
                },
                "token": {
                    "type": "string",
                    "format": "password",
                    "label": "API Token",
                    "help_text": "Your Trello API Token with required permissions. Generate it after obtaining your API Key."
                }
            }
        }
    },
    "actions": {
        "get_current_member": {
            "display_name": "Get Current Member",
            "description": "Returns information about the authenticated member.",
            "input_schema": {
                "type": "object",
                "properties": {},
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "member": {
                        "type": "object",
                        "description": "Member details"
                    }
                },
                "required": ["member"]
            }
        },
        "create_board": {
            "display_name": "Create Board",
            "description": "Creates a new board. Board name is required.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the board"
                    },
                    "desc": {
                        "type": "string",
                        "description": "Board description"
                    },
                    "defaultLists": {
                        "type": "boolean",
                        "description": "Whether to create default lists (To Do, Doing, Done)",
                        "default": true
                    },
                    "prefs_permissionLevel": {
                        "type": "string",
                        "description": "Permission level: private, org, or public",
                        "enum": ["private", "org", "public"]
                    },
                    "prefs_background": {
                        "type": "string",
                        "description": "Board background color (e.g., 'blue', 'green', 'red')"
                    }
                },
                "required": ["name"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "board": {
                        "type": "object",
                        "description": "Created board details"
                    }
                },
                "required": ["board"]
            }
        },
        "get_board": {
            "display_name": "Get Board",
            "description": "Retrieves details of a specific board by its ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "board_id": {
                        "type": "string",
                        "description": "The ID of the board to retrieve"
                    },
                    "fields": {
                        "type": "string",
                        "description": "Comma-separated list of fields to return (e.g., 'name,desc,url')"
                    }
                },
                "required": ["board_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "board": {
                        "type": "object",
                        "description": "Board details"
                    }
                },
                "required": ["board"]
            }
        },
        "update_board": {
            "display_name": "Update Board",
            "description": "Updates an existing board's details.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "board_id": {
                        "type": "string",
                        "description": "The ID of the board to update"
                    },
                    "name": {
                        "type": "string",
                        "description": "Updated board name"
                    },
                    "desc": {
                        "type": "string",
                        "description": "Updated board description"
                    },
                    "closed": {
                        "type": "boolean",
                        "description": "Whether the board is closed (archived)"
                    },
                    "prefs_permissionLevel": {
                        "type": "string",
                        "description": "Permission level: private, org, or public"
                    }
                },
                "required": ["board_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "board": {
                        "type": "object",
                        "description": "Updated board details"
                    }
                },
                "required": ["board"]
            }
        },
        "list_boards": {
            "display_name": "List Boards",
            "description": "Returns all boards for the authenticated member.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "filter": {
                        "type": "string",
                        "description": "Filter boards: all, open, closed, members, organization, public, starred",
                        "default": "open"
                    }
                },
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "boards": {
                        "type": "array",
                        "description": "List of boards"
                    },
                    "count": {
                        "type": "integer",
                        "description": "Number of boards returned"
                    }
                },
                "required": ["boards", "count"]
            }
        },
        "create_list": {
            "display_name": "Create List",
            "description": "Creates a new list on a board.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "board_id": {
                        "type": "string",
                        "description": "The ID of the board to create the list on"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name of the list"
                    },
                    "pos": {
                        "type": "string",
                        "description": "Position: 'top', 'bottom', or a positive number"
                    }
                },
                "required": ["board_id", "name"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "list": {
                        "type": "object",
                        "description": "Created list details"
                    }
                },
                "required": ["list"]
            }
        },
        "get_list": {
            "display_name": "Get List",
            "description": "Retrieves details of a specific list by its ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "list_id": {
                        "type": "string",
                        "description": "The ID of the list to retrieve"
                    }
                },
                "required": ["list_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "list": {
                        "type": "object",
                        "description": "List details"
                    }
                },
                "required": ["list"]
            }
        },
        "update_list": {
            "display_name": "Update List",
            "description": "Updates a list's properties.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "list_id": {
                        "type": "string",
                        "description": "The ID of the list to update"
                    },
                    "name": {
                        "type": "string",
                        "description": "Updated list name"
                    },
                    "closed": {
                        "type": "boolean",
                        "description": "Whether the list is closed (archived)"
                    },
                    "pos": {
                        "type": "string",
                        "description": "New position: 'top', 'bottom', or a positive number"
                    }
                },
                "required": ["list_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "list": {
                        "type": "object",
                        "description": "Updated list details"
                    }
                },
                "required": ["list"]
            }
        },
        "list_lists": {
            "display_name": "List Lists",
            "description": "Returns all lists on a board.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "board_id": {
                        "type": "string",
                        "description": "The ID of the board"
                    },
                    "filter": {
                        "type": "string",
                        "description": "Filter lists: all, open, closed",
                        "default": "open"
                    }
                },
                "required": ["board_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "lists": {
                        "type": "array",
                        "description": "List of lists"
                    },
                    "count": {
                        "type": "integer",
                        "description": "Number of lists returned"
                    }
                },
                "required": ["lists", "count"]
            }
        },
        "create_card": {
            "display_name": "Create Card",
            "description": "Creates a new card on a list.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "list_id": {
                        "type": "string",
                        "description": "The ID of the list to create the card on"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name of the card"
                    },
                    "desc": {
                        "type": "string",
                        "description": "Card description (supports Markdown)"
                    },
                    "pos": {
                        "type": "string",
                        "description": "Position: 'top', 'bottom', or a positive number"
                    },
                    "due": {
                        "type": "string",
                        "description": "Due date (ISO 8601 format)"
                    },
                    "idMembers": {
                        "type": "array",
                        "description": "Array of member IDs to assign to the card",
                        "items": {
                            "type": "string"
                        }
                    },
                    "idLabels": {
                        "type": "array",
                        "description": "Array of label IDs to add to the card",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["list_id", "name"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "card": {
                        "type": "object",
                        "description": "Created card details"
                    }
                },
                "required": ["card"]
            }
        },
        "get_card": {
            "display_name": "Get Card",
            "description": "Retrieves details of a specific card by its ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card to retrieve"
                    },
                    "fields": {
                        "type": "string",
                        "description": "Comma-separated list of fields to return"
                    }
                },
                "required": ["card_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "card": {
                        "type": "object",
                        "description": "Card details"
                    }
                },
                "required": ["card"]
            }
        },
        "update_card": {
            "display_name": "Update Card",
            "description": "Updates an existing card's details.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card to update"
                    },
                    "name": {
                        "type": "string",
                        "description": "Updated card name"
                    },
                    "desc": {
                        "type": "string",
                        "description": "Updated card description"
                    },
                    "closed": {
                        "type": "boolean",
                        "description": "Whether the card is closed (archived)"
                    },
                    "idList": {
                        "type": "string",
                        "description": "Move card to a different list (list ID)"
                    },
                    "due": {
                        "type": "string",
                        "description": "Updated due date (ISO 8601)"
                    },
                    "dueComplete": {
                        "type": "boolean",
                        "description": "Whether the due date is marked complete"
                    },
                    "idMembers": {
                        "type": "array",
                        "description": "Updated array of member IDs",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["card_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "card": {
                        "type": "object",
                        "description": "Updated card details"
                    }
                },
                "required": ["card"]
            }
        },
        "delete_card": {
            "display_name": "Delete Card",
            "description": "Deletes a card permanently.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card to delete"
                    }
                },
                "required": ["card_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "deleted": {
                        "type": "boolean",
                        "description": "True when the card was successfully deleted"
                    },
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card that was deleted"
                    }
                },
                "required": ["deleted", "card_id"]
            }
        },
        "get_card_attachments": {
            "display_name": "Get Card Attachments",
            "description": "List all attachments on a Trello card.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card to retrieve attachments for"
                    },
                    "filter": {
                        "type": "string",
                        "description": "Filter attachments: 'false' returns all, 'cover' returns only the cover attachment",
                        "default": "false"
                    }
                },
                "required": ["card_id"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "attachments": {
                        "type": "array",
                        "description": "List of attachment objects",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {"type": "string", "description": "Attachment ID"},
                                "name": {"type": "string", "description": "Attachment file name"},
                                "url": {"type": "string", "description": "URL to the attachment"},
                                "mimeType": {"type": "string", "description": "MIME type of the attachment"},
                                "bytes": {"type": "string", "description": "File size in bytes"},
                                "date": {"type": "string", "description": "Date the attachment was added (ISO 8601)"},
                                "isUpload": {"type": "boolean", "description": "True if the attachment was directly uploaded"},
                                "idMember": {"type": "string", "description": "ID of the member who added the attachment"},
                                "edgeColor": {"type": "string", "description": "Edge colour derived from the attachment image"},
                                "pos": {"type": "number", "description": "Position of the attachment"}
                            }
                        }
                    },
                    "count": {
                        "type": "integer",
                        "description": "Number of attachments returned"
                    }
                },
                "required": ["attachments", "count"]
            }
        },
        "list_cards": {
            "display_name": "List Cards",
            "description": "Returns cards on a list or board with cursor-based pagination. Uses Trello's server-side limit + before/since. Returns next_before when more results are likely available; pass it back as before to fetch the next page. Use search_cards for name-based lookups.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "list_id": {
                        "type": "string",
                        "description": "The ID of the list (use this or board_id)"
                    },
                    "board_id": {
                        "type": "string",
                        "description": "The ID of the board (use this or list_id)"
                    },
                    "filter": {
                        "type": "string",
                        "description": "Filter cards: all, open, closed, visible",
                        "default": "open"
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Server-side cap on cards per request (1-1000).",
                        "default": 50,
                        "minimum": 1,
                        "maximum": 1000
                    },
                    "before": {
                        "type": "string",
                        "description": "Cursor: only return cards created before this card ID or ISO 8601 date. Pass the next_before value from a previous response to paginate."
                    },
                    "since": {
                        "type": "string",
                        "description": "Cursor: only return cards created after this card ID or ISO 8601 date."
                    },
                    "fields": {
                        "type": "string",
                        "description": "Comma-separated card fields to return, or 'all'. Enforced client-side as well as via the API.",
                        "default": "id,name,idList,idBoard,due,dueComplete,closed,url,shortUrl"
                    }
                },
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "cards": {
                        "type": "array",
                        "description": "List of cards"
                    },
                    "count": {
                        "type": "integer",
                        "description": "Number of cards returned"
                    },
                    "next_before": {
                        "type": "string",
                        "description": "Cursor for the next page (the lexicographically smallest card ID in this response, i.e. the oldest-created card). Present only when a full page was returned, indicating more cards may exist. Pass this back as before."
                    }
                },
                "required": ["cards", "count"]
            }
        },
        "search_cards": {
            "display_name": "Search Cards",
            "description": "Searches Trello cards by name/text or advanced Trello search query. Use this when you don't know which board or list contains the card.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_name": {
                        "type": "string",
                        "description": "Card name/text to search for. The handler wraps this in Trello's name:\"...\" operator."
                    },
                    "query": {
                        "type": "string",
                        "description": "Advanced Trello search query (e.g. 'name:\"Bug\" list:\"In Progress\" label:red due:week'). Combined with card_name if both are provided."
                    },
                    "board_id": {
                        "type": "string",
                        "description": "Optional board ID to scope the search (sent as idBoards)."
                    },
                    "organization_id": {
                        "type": "string",
                        "description": "Optional Workspace/organization ID to scope the search (sent as idOrganizations)."
                    },
                    "open_only": {
                        "type": "boolean",
                        "description": "Restrict to open cards by appending is:open. Skipped if the query already specifies a card-status operator (is:open|closed|archived).",
                        "default": true
                    },
                    "partial": {
                        "type": "boolean",
                        "description": "Enable prefix matching, e.g. 'dev' matches 'Development'.",
                        "default": true
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Maximum number of cards to return (1-1000).",
                        "default": 10,
                        "minimum": 1,
                        "maximum": 1000
                    },
                    "page": {
                        "type": "integer",
                        "description": "Page of card search results for pagination.",
                        "default": 0,
                        "minimum": 0
                    },
                    "fields": {
                        "type": "string",
                        "description": "Comma-separated card fields to return, or 'all'.",
                        "default": "id,name,idList,idBoard,due,dueComplete,closed,url,shortUrl"
                    },
                    "include_board": {
                        "type": "boolean",
                        "description": "Include board details with each card.",
                        "default": true
                    },
                    "include_list": {
                        "type": "boolean",
                        "description": "Include list details with each card.",
                        "default": true
                    },
                    "include_members": {
                        "type": "boolean",
                        "description": "Include member details with each card.",
                        "default": false
                    },
                    "include_attachments": {
                        "type": "boolean",
                        "description": "Include attachments with each card.",
                        "default": false
                    }
                },
                "required": []
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "cards": {
                        "type": "array",
                        "description": "Matching Trello cards"
                    },
                    "count": {
                        "type": "integer",
                        "description": "Number of cards returned"
                    },
                    "options": {
                        "type": "object",
                        "description": "Trello search metadata/options"
                    }
                },
                "required": ["cards", "count", "options"]
            }
        },
        "create_checklist": {
            "display_name": "Create Checklist",
            "description": "Creates a new checklist on a card.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name of the checklist"
                    }
                },
                "required": ["card_id", "name"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "checklist": {
                        "type": "object",
                        "description": "Created checklist details"
                    }
                },
                "required": ["checklist"]
            }
        },
        "add_checklist_item": {
            "display_name": "Add Checklist Item",
            "description": "Adds a new item to a checklist.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "checklist_id": {
                        "type": "string",
                        "description": "The ID of the checklist"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name/text of the checklist item"
                    },
                    "checked": {
                        "type": "boolean",
                        "description": "Whether the item is checked",
                        "default": false
                    },
                    "pos": {
                        "type": "string",
                        "description": "Position: 'top', 'bottom', or a positive number"
                    }
                },
                "required": ["checklist_id", "name"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "checkItem": {
                        "type": "object",
                        "description": "Created checklist item details"
                    }
                },
                "required": ["checkItem"]
            }
        },
        "add_comment": {
            "display_name": "Add Comment",
            "description": "Adds a comment to a card.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "card_id": {
                        "type": "string",
                        "description": "The ID of the card"
                    },
                    "text": {
                        "type": "string",
                        "description": "The comment text (supports Markdown)"
                    }
                },
                "required": ["card_id", "text"]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "comment": {
                        "type": "object",
                        "description": "Created comment details"
                    }
                },
                "required": ["comment"]
            }
        }
    }
}
