{
    "name": "RSS Reader using Atoma and Autohive SDK fetch",
    "version": "2.0.0",
    "description": "An integration for reading RSS and Atom feeds using Atoma and the Autohive SDK fetch method.",
    "entry_point": "rss_reader.py",
    "auth": {
        "type": "custom",
        "title": "RSS Feed Authentication",
        "identifier": "rss_authentication",
        "fields": {
            "type": "object",
            "properties": {
                "user_name": {
                    "type": "string",
                    "format": "text",
                    "label": "Username for the RSS feed",
                    "help_text": "You'll get this from the RSS feed provider."
                },
                "password": {
                    "type": "string",
                    "format": "password",
                    "label": "Password for the RSS feed",
                    "help_text": "You'll get this from the RSS feed provider."
                },
                "api_token": {
                    "type": "string",
                    "format": "password",
                    "label": "API token for the RSS feed",
                    "help_text": "You'll get this from the RSS feed provider."
                }
            },
            "required": []
        }
    },
    "actions": {
        "get_feed": {
            "description": "Retrieve entries from an RSS feed.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "feed_url": {
                        "type": "string",
                        "description": "The URL of the RSS feed to read."
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Maximum number of entries to return.",
                        "default": 10
                    }
                },
                "required": [
                    "feed_url"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "feed_title": {
                        "type": "string",
                        "description": "Title of the RSS feed"
                    },
                    "feed_link": {
                        "type": "string",
                        "description": "Link to the RSS feed"
                    },
                    "entries": {
                        "type": "array",
                        "description": "Array of feed entries",
                        "items": {
                            "type": "object",
                            "properties": {
                                "title": {
                                    "type": "string",
                                    "description": "Entry title"
                                },
                                "link": {
                                    "type": "string",
                                    "description": "Link to entry"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "The description of the entry"
                                },
                                "published": {
                                    "type": "string",
                                    "description": "Published date"
                                },
                                "author": {
                                    "type": "string",
                                    "description": "Author"
                                }
                            }
                        }
                    }
                }
            },
            "display_name": "Get Feed"
        }
    },
    "display_name": "RSS Reader using Atoma and Autohive SDK fetch"
}
