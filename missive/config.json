{
    "name": "Missive",
    "version": "1.0.0",
    "description": "Missive integration for managing conversations, messages, drafts, contacts, and analytics in your team inbox.",
    "display_name": "Missive",
    "supports_connected_account": false,
    "entry_point": "missive.py",
    "auth": {
        "type": "custom",
        "title": "Missive API Token",
        "fields": {
            "type": "object",
            "properties": {
                "api_token": {
                    "type": "string",
                    "format": "password",
                    "label": "API Token",
                    "help_text": "Generate your token in Missive \u00e2\u2020\u2019 Preferences \u00e2\u2020\u2019 API. Requires the Productive plan."
                }
            }
        }
    },
    "actions": {
        "list_conversations": {
            "display_name": "List Conversations",
            "description": "List conversations filtered by mailbox type. Supports inbox, all, assigned, closed, snoozed, flagged, trashed, junked, drafts, shared_label, team_inbox, team_closed, and team_all.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "mailbox": {
                        "type": "string",
                        "description": "Mailbox filter",
                        "enum": [
                            "inbox",
                            "all",
                            "assigned",
                            "closed",
                            "snoozed",
                            "flagged",
                            "trashed",
                            "junked",
                            "drafts",
                            "shared_label",
                            "team_inbox",
                            "team_closed",
                            "team_all"
                        ]
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Number of conversations to return (max 50)",
                        "default": 25,
                        "minimum": 2
                    },
                    "until": {
                        "type": "number",
                        "description": "Pagination cursor \u00e2\u20ac\u201d pass last_activity_at of the last conversation to get the next page"
                    },
                    "team_id": {
                        "type": "string",
                        "description": "Team UUID \u2014 required when mailbox is team_inbox, team_closed, or team_all"
                    },
                    "shared_label_id": {
                        "type": "string",
                        "description": "Shared label UUID \u2014 required when mailbox is shared_label"
                    }
                },
                "required": [
                    "mailbox"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "conversations": {
                        "type": "array",
                        "description": "List of conversations"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "conversations",
                    "result"
                ]
            }
        },
        "get_conversation": {
            "display_name": "Get Conversation",
            "description": "Retrieve a specific conversation by ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "The conversation ID"
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "conversation": {
                        "type": "object",
                        "description": "Conversation details"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "conversation",
                    "result"
                ]
            }
        },
        "update_conversation": {
            "display_name": "Update Conversation",
            "description": "Update conversation state \u00e2\u20ac\u201d close, reopen, assign, snooze, add/remove labels, change subject or color. Supports comma-separated IDs for bulk updates.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "Conversation ID or comma-separated IDs for bulk update"
                    },
                    "subject": {
                        "type": "string",
                        "description": "New subject"
                    },
                    "color": {
                        "type": "string",
                        "description": "Conversation color label"
                    },
                    "assignee_id": {
                        "type": "string",
                        "description": "User ID to assign the conversation to"
                    },
                    "team_id": {
                        "type": "string",
                        "description": "Team ID to assign the conversation to"
                    },
                    "shared_label_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Shared label IDs to apply"
                    },
                    "closed": {
                        "type": "boolean",
                        "description": "Set true to close, false to reopen"
                    },
                    "snoozed_until": {
                        "type": "number",
                        "description": "Unix timestamp to snooze until"
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "merge_conversations": {
            "display_name": "Merge Conversations",
            "description": "Merge a source conversation into a target conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "Source conversation ID to merge"
                    },
                    "target_conversation_id": {
                        "type": "string",
                        "description": "Target conversation ID to merge into"
                    }
                },
                "required": [
                    "conversation_id",
                    "target_conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "list_conversation_messages": {
            "display_name": "List Conversation Messages",
            "description": "List all messages in a specific conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "The conversation ID"
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Number of messages to return (max 10)",
                        "default": 10
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "messages": {
                        "type": "array",
                        "description": "List of messages"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "messages",
                    "result"
                ]
            }
        },
        "list_conversation_comments": {
            "display_name": "List Conversation Comments",
            "description": "List internal comments in a specific conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "The conversation ID"
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "comments": {
                        "type": "array",
                        "description": "List of comments"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "comments",
                    "result"
                ]
            }
        },
        "list_conversation_posts": {
            "display_name": "List Conversation Posts",
            "description": "List system posts in a specific conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "The conversation ID"
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "posts": {
                        "type": "array",
                        "description": "List of posts"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "posts",
                    "result"
                ]
            }
        },
        "list_conversation_drafts": {
            "display_name": "List Conversation Drafts",
            "description": "List draft messages in a specific conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "The conversation ID"
                    }
                },
                "required": [
                    "conversation_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "drafts": {
                        "type": "array",
                        "description": "List of drafts"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "drafts",
                    "result"
                ]
            }
        },
        "list_messages": {
            "display_name": "List Messages",
            "description": "List messages across all conversations.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "limit": {
                        "type": "integer",
                        "description": "Number of messages to return",
                        "default": 25,
                        "minimum": 2
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "messages": {
                        "type": "array",
                        "description": "List of messages"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "messages",
                    "result"
                ]
            }
        },
        "get_message": {
            "display_name": "Get Message",
            "description": "Retrieve a specific message by ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "message_id": {
                        "type": "string",
                        "description": "The message ID"
                    }
                },
                "required": [
                    "message_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "object",
                        "description": "Message details"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "message",
                    "result"
                ]
            }
        },
        "create_message": {
            "display_name": "Create Message",
            "description": "Create an incoming message in a custom channel, simulating a message received from an external system.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "channel_id": {
                        "type": "string",
                        "description": "Custom channel ID to receive the message"
                    },
                    "account": {
                        "type": "string",
                        "description": "Account ID that owns the custom channel"
                    },
                    "from_field": {
                        "type": "object",
                        "description": "Sender identity for the message",
                        "properties": {
                            "name": {"type": "string"},
                            "username": {"type": "string"}
                        }
                    },
                    "to_fields": {
                        "type": "array",
                        "description": "Recipient identities",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {"type": "string"},
                                "username": {"type": "string"}
                            }
                        }
                    },
                    "body": {
                        "type": "string",
                        "description": "Message body text"
                    },
                    "subject": {
                        "type": "string",
                        "description": "Message subject"
                    },
                    "sender": {
                        "type": "object",
                        "description": "Sender details",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "handle": {
                                "type": "string"
                            }
                        }
                    },
                    "conversation_id": {
                        "type": "string",
                        "description": "Append to existing conversation (optional)"
                    },
                    "external_id": {
                        "type": "string",
                        "description": "External ID for deduplication"
                    }
                },
                "required": [
                    "channel_id",
                    "account",
                    "from_field",
                    "to_fields",
                    "body"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "object",
                        "description": "Created message"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "create_draft": {
            "display_name": "Create Draft",
            "description": "Create an email, SMS, WhatsApp, or custom channel draft. Set send to true to send immediately. Supports scheduling via send_at.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "channel_id": {
                        "type": "string",
                        "description": "Channel ID to send from"
                    },
                    "subject": {
                        "type": "string",
                        "description": "Email subject"
                    },
                    "body": {
                        "type": "string",
                        "description": "Message body (HTML supported for email)"
                    },
                    "to": {
                        "type": "array",
                        "description": "Recipients",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "address": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "cc": {
                        "type": "array",
                        "description": "CC recipients",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "address": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "bcc": {
                        "type": "array",
                        "description": "BCC recipients",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "address": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "conversation_id": {
                        "type": "string",
                        "description": "Conversation ID to reply in"
                    },
                    "send": {
                        "type": "boolean",
                        "description": "Send immediately if true",
                        "default": false
                    },
                    "send_at": {
                        "type": "number",
                        "description": "Unix timestamp to schedule send"
                    },
                    "auto_followup": {
                        "type": "boolean",
                        "description": "Enable auto follow-up if no reply"
                    },
                    "team_id": {
                        "type": "string",
                        "description": "Assign to a team"
                    },
                    "assignee_id": {
                        "type": "string",
                        "description": "Assign to a user"
                    }
                },
                "required": [
                    "channel_id",
                    "body"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "draft": {
                        "type": "object",
                        "description": "Created draft details"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "delete_draft": {
            "display_name": "Delete Draft",
            "description": "Delete a draft from a conversation.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "draft_id": {
                        "type": "string",
                        "description": "The draft ID to delete"
                    }
                },
                "required": [
                    "draft_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "create_post": {
            "display_name": "Create Post",
            "description": "Inject a post into a conversation. Can also manage conversation state (close, assign, label) as part of the same operation. Creates a new conversation if no ID is provided.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "description": "Conversation ID to post into (omit to create a new conversation)"
                    },
                    "text": {
                        "type": "string",
                        "description": "Post text content"
                    },
                    "subject": {
                        "type": "string",
                        "description": "New conversation subject (for new conversations)"
                    },
                    "close": {
                        "type": "boolean",
                        "description": "Close the conversation after posting"
                    },
                    "reopen": {
                        "type": "boolean",
                        "description": "Reopen a closed conversation"
                    },
                    "assignee_id": {
                        "type": "string",
                        "description": "Assign conversation to this user"
                    },
                    "team_id": {
                        "type": "string",
                        "description": "Assign conversation to this team"
                    },
                    "shared_label_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Apply these shared label IDs"
                    }
                },
                "required": [
                    "text"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "post": {
                        "type": "object",
                        "description": "Created post details"
                    },
                    "conversation": {
                        "type": "object",
                        "description": "Updated conversation details"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "list_contacts": {
            "display_name": "List Contacts",
            "description": "List contacts with optional search and filtering. Returns up to 200 results per page.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "search": {
                        "type": "string",
                        "description": "Search query to filter contacts"
                    },
                    "contact_book_id": {
                        "type": "string",
                        "description": "Filter by contact book"
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Number of contacts to return (max 200)",
                        "default": 50
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contacts": {
                        "type": "array",
                        "description": "List of contacts"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "contacts",
                    "result"
                ]
            }
        },
        "get_contact": {
            "display_name": "Get Contact",
            "description": "Retrieve a specific contact by ID.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "contact_id": {
                        "type": "string",
                        "description": "The contact ID"
                    }
                },
                "required": [
                    "contact_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contact": {
                        "type": "object",
                        "description": "Contact details"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "contact",
                    "result"
                ]
            }
        },
        "create_contact": {
            "display_name": "Create Contact",
            "description": "Create one or more contacts with names, emails, phone numbers, and other details.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "contacts": {
                        "type": "array",
                        "description": "List of contacts to create",
                        "items": {
                            "type": "object",
                            "properties": {
                                "first_name": {
                                    "type": "string"
                                },
                                "last_name": {
                                    "type": "string"
                                },
                                "job_title": {
                                    "type": "string"
                                },
                                "notes": {
                                    "type": "string"
                                },
                                "infos": {
                                    "type": "array",
                                    "description": "Contact info items (email, phone, etc.)",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "type": {
                                                "type": "string",
                                                "description": "e.g. email, phone"
                                            },
                                            "value": {
                                                "type": "string"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "contact_book_id": {
                        "type": "string",
                        "description": "ID of the contact book to add contacts to"
                    }
                },
                "required": [
                    "contacts",
                    "contact_book_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contacts": {
                        "type": "array",
                        "description": "Created contacts"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "update_contact": {
            "display_name": "Update Contact",
            "description": "Update a contact's details. Note: infos and memberships arrays must be provided in full as they replace existing values.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "contact_id": {
                        "type": "string",
                        "description": "The contact ID to update"
                    },
                    "first_name": {
                        "type": "string"
                    },
                    "last_name": {
                        "type": "string"
                    },
                    "job_title": {
                        "type": "string"
                    },
                    "notes": {
                        "type": "string"
                    },
                    "infos": {
                        "type": "array",
                        "description": "Full replacement array of contact info items",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string"
                                },
                                "value": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "contact_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contact": {
                        "type": "object",
                        "description": "Updated contact"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "result"
                ]
            }
        },
        "list_contact_books": {
            "display_name": "List Contact Books",
            "description": "List all contact books accessible to the authenticated user.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "limit": {
                        "type": "integer",
                        "description": "Number of contact books to return (max 200)",
                        "default": 50
                    }
                }
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contact_books": {
                        "type": "array",
                        "description": "List of contact books"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "contact_books",
                    "result"
                ]
            }
        },
        "list_contact_groups": {
            "display_name": "List Contact Groups",
            "description": "List groups or organizations within a contact book.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "contact_book_id": {
                        "type": "string",
                        "description": "The contact book ID"
                    },
                    "kind": {
                        "type": "string",
                        "description": "Filter by kind: group or organization",
                        "enum": [
                            "group",
                            "organization"
                        ]
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Number of groups to return (max 200)",
                        "default": 50
                    }
                },
                "required": [
                    "contact_book_id"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "contact_groups": {
                        "type": "array",
                        "description": "List of contact groups"
                    },
                    "result": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "contact_groups",
                    "result"
                ]
            }
        },
        "create_analytics_report": {
            "display_name": "Create Analytics Report",
            "description": "Generate an analytics report asynchronously. Reports complete within 2\u00e2\u20ac\u201c30 seconds. Use get_analytics_report to retrieve results. Requires Business or Productive plan.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "start": {
                        "type": "number",
                        "description": "Report start time as Unix timestamp"
                    },
                    "end": {
                        "type": "number",
                        "description": "Report end time as Unix timestamp"
                    },
                    "timezone": {
                        "type": "string",
                        "description": "Timezone for the report (e.g. America/New_York)"
                    },
                    "team_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Filter by team IDs (Business plan required)"
                    },
                    "user_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Filter by user IDs (Business plan required)"
                    },
                    "shared_label_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Filter by shared label IDs (Business plan required)"
                    },
                    "organization_id": {
                        "type": "string",
